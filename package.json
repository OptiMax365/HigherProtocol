{
  "name": "quotecards-pro",
  "version": "1.0.0",
  "description": "Production quote card generator with Stripe subscriptions, user auth, and admin dashboard",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo '✅ Frontend is static - no build step required'",
    "postinstall": "echo '✅ Dependencies installed successfully'",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "stripe:listen": "stripe listen --forward-to localhost:10000/api/webhook",
    "deploy:render": "git push render main",
    "health": "curl -f https://higherprotocola3.onrender.com/health || echo '❌ Server not responding'"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "stripe": "^14.8.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0 <21.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "quote-generator",
    "canvas",
    "stripe",
    "subscriptions",
    "express",
    "postgresql",
    "jwt-auth",
    "admin-dashboard"
  ],
  "author": {
    "name": "QuoteCards Team",
    "email": "olusolaayodeji5112@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/optimax365/quotecards-pro.git"
  },
  "bugs": {
    "url": "https://github.com/optimax365/quotecards-pro/issues"
  },
  "homepage": "https://optimax365.github.io",
  "private": false,
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server.js",
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 80,
        "statements": 80
      }
    },
    "setupFiles": [
      "dotenv/config"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off"
    }
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules/**",
      "*.log",
      "public/**",
      ".git"
    ],
    "delay": "1000",
    "ext": "js,json"
  },
  "render": {
    "buildCommand": "npm install --production",
    "startCommand": "node server.js",
    "envVars": [
      "NODE_ENV",
      "PORT",
      "DATABASE_URL",
      "JWT_SECRET",
      "STRIPE_SECRET_KEY",
      "STRIPE_PUBLISHABLE_KEY",
      "STRIPE_WEBHOOK_SECRET",
      "CORS_ORIGIN",
      "ADMIN_EMAIL",
      "ADMIN_PASSWORD",
      "SMTP_HOST",
      "SMTP_PORT",
      "SMTP_USER",
      "SMTP_PASS"
    ]
  }
}
